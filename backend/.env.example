# ==========================================================================
#   VULCAN FORGE — Plantilla de Variables de Entorno
#   Copia este archivo como .env y completa los valores reales
# ==========================================================================

# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- JWT: genera uno nuevo con: ---
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REEMPLAZA_CON_UN_SECRETO_ALEATORIO_DE_96_CHARS

# --- Expiración del token (8h, 1d, 30m, etc.) ---
JWT_EXPIRES_IN=8h

# --- Hashing: rondas bcrypt (12 recomendado para producción) ---
BCRYPT_ROUNDS=12

# --- CORS: origen del frontend permitido ---
CORS_ORIGIN=http://localhost:3001

# --- Contraseñas iniciales (solo se usan al crear vulcan-data.json por primera vez) ---
SEED_ADMIN_PASSWORD=REEMPLAZA_CONTRASEÑA_ADMIN
SEED_WAREHOUSE_PASSWORD=REEMPLAZA_CONTRASEÑA_WAREHOUSE
SEED_CASHIER_PASSWORD=REEMPLAZA_CONTRASEÑA_CASHIER
